#!/usr/bin/env bash

# Install Neovim package via Brew (macOS) or Pacman (Arch Linux)
if command -v brew >/dev/null; then
  echo "Installing Neovim via Homebrew..."
  if brew list neovim >/dev/null 2>&1; then
    echo "Neovim already installed via Homebrew. Upgrading..."
    brew upgrade neovim
  else
    brew install neovim
  fi
elif command -v pacman >/dev/null; then
  echo "Installing Neovim via Pacman..."
  pacman -Qi neovim >/dev/null 2>&1 || sudo pacman -S --noconfirm neovim
elif command -v apt-get >/dev/null; then
  echo "Installing Neovim via apt-get..."
  dpkg -s neovim >/dev/null 2>&1 || {
    sudo apt-get update
    sudo apt-get install -y neovim
  }
else
  echo "Unsupported system. Please install neovim manually."
  exit 1
fi
